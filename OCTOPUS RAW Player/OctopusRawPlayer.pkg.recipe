<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Description</key>
    <string>Downloads the latest version of OCTOPUS RAW Player and creates a repackaged installer.</string>
    <key>Identifier</key>
    <string>com.github.Woodmember-Autopkg-Recipes.pkg.OctopusRawPlayer</string>
    <key>Input</key>
    <dict>
        <key>NAME</key>
        <string>OctopusRawPlayer</string>
        <key>pkginfo</key>
        <dict>
            <key>catalogs</key>
            <array>
                <string>testing</string>
            </array>
            <key>description</key>
            <string>OCTOPUS RAW Player is a lightweight multi-platform video player for reviewing RAW video footage from professional cameras. It supports CinemaDNG RAW sequences with advanced color science processing and various output formats including Log gamma/wide gamut options.</string>
            <key>developer</key>
            <string>OCTOPUS CINEMA</string>
            <key>display_name</key>
            <string>OCTOPUS RAW Player</string>
            <key>name</key>
            <string>%NAME%</string>
            <key>unattended_install</key>
            <true/>
        </dict>
    </dict>
    <key>MinimumVersion</key>
    <string>2.3</string>
    <key>ParentRecipe</key>
    <string>com.github.Woodmember-Autopkg-Recipes.download.OctopusRawPlayer</string>
    <key>Process</key>
    <array>
        <!-- Create the package using AppPkgCreator -->
        <dict>
            <key>Comment</key>
            <string>Create OCTOPUS RAW Player package</string>
            <key>Processor</key>
            <string>AppPkgCreator</string>
            <key>Arguments</key>
            <dict>
                <key>app_path</key>
                <string>%found_filename%</string>
            </dict>
        </dict>
        
        <!-- Clean up temporary directories from download recipe -->
        <dict>
            <key>Comment</key>
            <string>Clean up unpack directory</string>
            <key>Processor</key>
            <string>PathDeleter</string>
            <key>Arguments</key>
            <dict>
                <key>path_list</key>
                <array>
                    <string>%RECIPE_CACHE_DIR%/unpack</string>
                </array>
            </dict>
        </dict>
        
        <dict>
            <key>Comment</key>
            <string>Clean up extracted directory</string>
            <key>Processor</key>
            <string>PathDeleter</string>
            <key>Arguments</key>
            <dict>
                <key>path_list</key>
                <array>
                    <string>%RECIPE_CACHE_DIR%/extracted</string>
                </array>
            </dict>
        </dict>

    </array>
</dict>
</plist>
