<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Description</key>
    <string>Copies "Install Nessus Agent.pkg" from the downloaded DMG and renames it
following the %NAME%-%version% convention for Jamf Pro deployment.
PkgCopier is used instead of Copier to ensure pkg_path is set as an output
variable for use by jamfuploader and other downstream recipes.
</string>
    <key>Identifier</key>
    <string>com.github.Woodmember-Autopkg-Recipes.pkg.NessusAgent</string>
    <key>Input</key>
    <dict>
        <key>NAME</key>
        <string>NessusAgent</string>
    </dict>
    <key>MinimumVersion</key>
    <string>1.0.0</string>
    <key>ParentRecipe</key>
    <string>com.github.Woodmember-Autopkg-Recipes.download.NessusAgent</string>
    <key>Process</key>
    <array>

        <!-- ============================================================ -->
        <!-- Copy "Install Nessus Agent.pkg" from inside the DMG and      -->
        <!-- rename it to follow the %NAME%-%version% convention required -->
        <!-- by jamfuploader. PkgCopier sets pkg_path as an output        -->
        <!-- variable for use by downstream recipes.                      -->
        <!-- ============================================================ -->
        <dict>
            <key>Comment</key>
            <string>Copy Install Nessus Agent.pkg from DMG, rename for Jamf</string>
            <key>Processor</key>
            <string>PkgCopier</string>
            <key>Arguments</key>
            <dict>
                <key>source_pkg</key>
                <string>%pathname%/Install Nessus Agent.pkg</string>
                <key>pkg_path</key>
                <string>%RECIPE_CACHE_DIR%/%NAME%-%version%.pkg</string>
            </dict>
        </dict>

    </array>
</dict>
</plist>
