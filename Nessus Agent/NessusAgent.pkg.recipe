<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Description</key>
    <string>Extracts Install Nessus Agent.pkg from the downloaded DMG and stages it for deployment with standard naming.</string>
    <key>Identifier</key>
    <string>com.github.Woodmember-Autopkg-Recipes.pkg.NessusAgent</string>
    <key>Input</key>
    <dict>
        <key>NAME</key>
        <string>NessusAgent</string>
        <key>pkg_path</key>
        <string>%RECIPE_CACHE_DIR%/%NAME%-%version%.pkg</string>
    </dict>
    <key>MinimumVersion</key>
    <string>2.3</string>
    <key>ParentRecipe</key>
    <string>com.github.Woodmember-Autopkg-Recipes.download.NessusAgent</string>
    <key>Process</key>
    <array>

        <dict>
            <key>Comment</key>
            <string>Extract Install Nessus Agent.pkg from the DMG</string>
            <key>Processor</key>
            <string>Copier</string>
            <key>Arguments</key>
            <dict>
                <key>source_path</key>
                <string>%pathname%/Install Nessus Agent.pkg</string>
                <key>destination_path</key>
                <string>%RECIPE_CACHE_DIR%/%NAME%-%version%.pkg</string>
                <key>overwrite</key>
                <true/>
            </dict>
        </dict>

        <dict>
            <key>Comment</key>
            <string>Verify code signature of the extracted Nessus Agent PKG</string>
            <key>Processor</key>
            <string>CodeSignatureVerifier</string>
            <key>Arguments</key>
            <dict>
                <key>input_path</key>
                <string>%RECIPE_CACHE_DIR%/%NAME%-%version%.pkg</string>
                <key>requirement</key>
                <string>anchor apple generic and certificate leaf[subject.CN] = "Developer ID Installer: Tenable, Inc." and certificate 1[field.1.2.840.113635.100.6.2.6] /* exists */ and certificate leaf[field.1.2.840.113635.100.6.1.13] /* exists */</string>
            </dict>
        </dict>

    </array>
</dict>
</plist>
